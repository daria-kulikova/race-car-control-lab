<launch>
    <arg name="estimator_config" default="$(find ros_estimators)/config/pacejka_car_ekf.yaml" />
    <arg name="input_topic" default="control_input" />
    <arg name="vicon_topic" default="vicon" />
    <arg name="imu_topic" default="imu" />
    <arg name="imu_yaw_rate_topic" default="imu" />
    <arg name="wheel_encoder_topic" default="wheel_encoders" />
    <arg name="lighthouse_topic" default="lighthouse" />
    <arg name="state_est_topic" default="estimation_node/best_state" />

    <arg name="world_frame" default="world" />
    <arg name="track_frame" default="world" />
    <arg name="update_track_transform" default="false" />

    <arg name = "estimator_name" default = "estimation_node" />
    <arg name = "frame_name" default = "frame_name" />

    <node pkg="ros_estimators" name="$(arg estimator_name)" type="ros_estimation_node" output="screen">
        <rosparam command="load" file="$(arg estimator_config)" />
        <remap from="imu" to="$(arg imu_topic)" />
        <remap from="imu_yaw_rate" to="$(arg imu_yaw_rate_topic)" />
        <remap from="vicon" to="$(arg vicon_topic)" />
        <remap from="wheel_encoders" to="$(arg wheel_encoder_topic)" />
        <remap from="control_input" to="$(arg input_topic)" />
        <remap from="lighthouse"    to="$(arg lighthouse_topic)" />
        <remap from="state_est" to="$(arg state_est_topic)" />

        <param name="world_frame" type="str" value="$(arg world_frame)"></param>
        <param name="track_frame" type="str" value="$(arg track_frame)"></param>
        <param name="update_track_transform" type="bool" value="$(arg update_track_transform)"></param>

        <param name="car_frame_name" type="str" value="$(arg frame_name)"></param>
    </node>

</launch>
