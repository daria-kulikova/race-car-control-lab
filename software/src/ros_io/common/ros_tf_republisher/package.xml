<?xml version="1.0"?>
<package format="2">
  <name>ros_tf_republisher</name>
  <version>0.0.2</version>
  <description>Utility node splitting /tf into multiple distinct topics.</description>

  <author email="vogellu@ethz.ch">Lukas Vogel</author>
  <maintainer email="vogellu@ethz.ch">Lukas Vogel</maintainer>

  <license>BSD 2-Clause </license>

  <buildtool_depend>catkin</buildtool_depend>
  <buildtool_depend>catkin_simple</buildtool_depend>
  <depend>roscpp</depend>
  <depend>std_msgs</depend>

  <depend>eigen_catkin</depend>
  <depend>eigen_conversions</depend>

  <depend>tf2</depend>
  <depend>tf2_ros</depend>
  <depend>tf2_geometry_msgs</depend>

  <depend>commons</depend>

  <depend>crs_msgs</depend>
  <depend>ros_crs_utils</depend>

  <export></export>
